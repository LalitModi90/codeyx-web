{
  "manifest_version": 3,
  "name": "Codeyx Universal Sync",
  "version": "2.0.0",
  "description": "Automatically track and sync coding activity across all platforms in real-time.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "background"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.geeksforgeeks.org/*",
    "https://codeforces.com/*",
    "https://www.codechef.com/*",
    "https://www.hackerrank.com/*",
    "https://atcoder.jp/*",
    "https://github.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:5005/*",
    "http://localhost:5005/*",
    "https://codeyx-api.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://*.geeksforgeeks.org/*",
        "https://codeforces.com/*",
        "https://www.codechef.com/*",
        "https://www.hackerrank.com/*",
        "https://atcoder.jp/*",
        "https://github.com/*",
        "http://localhost:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://*.geeksforgeeks.org/problems/*"
      ],
      "js": ["inject-loader.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
