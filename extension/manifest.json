{
  "manifest_version": 3,
  "name": "Codeyx Sync",
  "version": "1.0",
  "description": "Auto-sync your LeetCode submissions to Codeyx in real-time.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:5005/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
