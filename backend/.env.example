# Port configuration
PORT=5005

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# MONGODB connection URI (Used for main Codeyx storage)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.bubjmca.mongodb.net/codeyx?retryWrites=true&w=majority

# Upstash Redis Configuration (Used for dashboard and API caching)
UPSTASH_REDIS_REST_URL=https://<your-redis-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-redis-rest-token>

# GitHub API Token (Optional but highly recommended to bypass rate limits)
# Create a Personal Access Token with read:user permissions
GITHUB_TOKEN=your_personal_access_token_here

# JWT Secret
JWT_SECRET=supersecretjwtkey_change_in_production

# Node Environment
NODE_ENV=development
